{
  "name": "imprint",
  "private": true,
  "version": "0.1.0",
  "description": "Composable agent identity system with a reusable core engine and CLI.",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "npm run generate:registry && npm run build --workspaces",
    "clean": "node scripts/clean.mjs",
    "generate:registry": "node scripts/generate-registry.mjs",
    "lint": "npm run typecheck --workspaces",
    "test": "npm run generate:registry && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "cli",
    "composition",
    "registry",
    "typescript"
  ],
  "author": "Mainline",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "execa": "^9.5.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "yaml": "^2.7.0"
  }
}
