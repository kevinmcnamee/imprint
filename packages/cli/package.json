{
  "name": "agent-composer",
  "version": "0.1.0",
  "description": "CLI for composing agent identities from modular trait cards.",
  "type": "module",
  "bin": {
    "composer": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --config ../../tsup.config.ts --banner.js '#!/usr/bin/env node'",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.3",
    "@mainline/composer": "0.1.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  }
}
