{
  "name": "@mainline/composer",
  "version": "0.1.0",
  "description": "Core composition engine for Agent Composer.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "build": "tsup src/index.ts --config ../../tsup.config.ts",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  }
}
