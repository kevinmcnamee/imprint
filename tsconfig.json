{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@mainline/composer": ["packages/core/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "scripts/**/*.mjs",
    "vitest.config.ts"
  ]
}
